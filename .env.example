# xfire Environment Variables

# GitHub API token (required for PR analysis)
GITHUB_TOKEN=

# Agent API keys (required for API mode, not needed for CLI mode)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional: Override config file path
XFIRE_CONFIG_PATH=

# Optional: Cache directory for context/intent persistence across runs
XFIRE_CACHE_DIR=

# Optional: Override path to auth.json credential store
XFIRE_AUTH_PATH=
